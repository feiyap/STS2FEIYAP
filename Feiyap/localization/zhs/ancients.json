{
  "NEOW.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-0.char": "我准备好了。",
  "NEOW.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-0.next": "继续",
  "NEOW.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-1.ancient": "[sine]去吧……用这份模板……搭出你的角色……[/sine]",
  "DARV.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-0.char": "这里还很空。",
  "DARV.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-0.next": "继续",
  "DARV.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-1.ancient": "空白正好！随便拿点东西填进去吧！",

  "THE_ARCHITECT.talk.FEIYAP_CHARACTER_FEIYAP.0-0r.char": "这里就是我的终点了吗？",
  "THE_ARCHITECT.talk.FEIYAP_CHARACTER_FEIYAP.0-0r.next": "继续。",
  "THE_ARCHITECT.talk.FEIYAP_CHARACTER_FEIYAP.0-1r.ancient": "暂时还不是。",
  "THE_ARCHITECT.talk.FEIYAP_CHARACTER_FEIYAP.0-attack": "Both",
  
  "FEIYAP_EVENT_ZHAN_XING_GUAN.title": "绯夜氏",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.epithet": "斩星官",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.pages.INITIAL.description": "无边无际的星空中，她茕茕孑立。黑洞在她的掌心诞生而又湮灭。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.firstVisitEver.0-0.ancient": "被引力吸引至此的旅人，若是再向前踏步，迎接你的只有毁灭。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.ANY.0-0r.ancient": "你再一次被引力吸引至此。循环往复。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.ANY.1-0r.ancient": "就连光都无法逃脱我，更何况是你呢？",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-0.ancient": "啊。是未完成的素体。你还在寻找终点吗？可惜，你找错了路。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-0.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-1.char": "……你认得我？",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-1.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.0-2.ancient": "这条路的尽头没有未来，只有可悲的虚无而已。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.1-0r.ancient": "不管重复多少次，未来仍旧不会改变。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.2-0.ancient": "你的坚持毫无意义。你到底在追寻什么？",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.2-0.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.2-1.char": "……我除了不停前进，又能做什么呢？",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.2-1.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.FEIYAP_CHARACTER_FEIYAP_CHARACTER.2-2.ancient": "……收下这个吧。你的未来不该在此断绝。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.IRONCLAD.0-0.ancient": "战士，你的怒火像超新星。亮，但也会灼伤持剑之人。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.IRONCLAD.1-0r.ancient": "又来了。火星未冷，别急着把一切都烧成灰烬。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.IRONCLAD.2-0.ancient": "挑一件吧。重力会替你收好那些沉不下去的执念。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.IRONCLAD.2-0.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.IRONCLAD.2-1.char": "……我只需要能砍下去的东西。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.IRONCLAD.2-1.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.IRONCLAD.2-2.ancient": "那就带着它去。别让你的火焰先于你的意志熄灭。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.SILENT.0-0.ancient": "猎手，你的脚步很轻。轻到连星光都来不及记录。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.SILENT.1-0r.ancient": "沉默很好。宇宙本就诞生于一片无声。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.SILENT.2-0.ancient": "选一件。别问名字——名字在星尘里留不久。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.SILENT.2-0.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.SILENT.2-1.char": "……",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.SILENT.2-1.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.SILENT.2-2.ancient": "去吧。最锋利的刀，往往没有回声。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.DEFECT.0-0.ancient": "构装体……你的核心频率很稳，像脉冲星。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.DEFECT.1-0r.ancient": "<平稳的嘀嘀声>……我听得见。信号也会穿越黑暗。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.DEFECT.2-0.ancient": "挑一件。把它当作校准你轨道的砝码。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.DEFECT.2-0.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.DEFECT.2-1.char": "[i][font_size=22]<迟疑的嘀嘀声>[/font_size][/i]",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.DEFECT.2-1.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.DEFECT.2-2.ancient": "去吧。别让你的节拍被任何引力拽离航线。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.NECROBINDER.0-0.ancient": "女士，恨意也是引力。它会把一切都拖向同一个深渊。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.NECROBINDER.1-0r.ancient": "你仍未松手。很好——复仇也需要轨道。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.NECROBINDER.2-0.ancient": "选一件。让它的重量替你记住尚未清算的星夜。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.NECROBINDER.2-0.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.NECROBINDER.2-1.char": "……我会记得。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.NECROBINDER.2-1.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.NECROBINDER.2-2.ancient": "那就带着它。黑洞边缘的光，往往最刺目。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.REGENT.0-0.ancient": "殿下，王冠的重量与恒星相当。你扛得住吗？",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.REGENT.1-0r.ancient": "欢迎回来。今日星象仍向您倾斜——但倾斜不等于坠落。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.REGENT.2-0.ancient": "挑一件。权柄需要实体，才能压得住乱飞的彗星。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.REGENT.2-0.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.REGENT.2-1.char": "……本王不会辜负星象的期许。",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.REGENT.2-1.next": "继续",
  "FEIYAP_EVENT_ZHAN_XING_GUAN.talk.REGENT.2-2.ancient": "很好。统治星辰的人，先得学会与黑暗共处。"
}
